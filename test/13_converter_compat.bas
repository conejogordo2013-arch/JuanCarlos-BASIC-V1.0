10 CLS
20 READ A$,T$,D$
30 IF A$="END" THEN 90
40 IF T$="PF" THEN GOSUB 200
50 IF T$="MF" THEN GOSUB 300
60 IF T$="VF" THEN GOSUB 400
70 IF T$="AF" THEN GOSUB 500
80 GOTO 20
90 END
200 H$="":FOR I=1 TO LEN(D$):C=ASC(MID$(D$,I,1)):N1=INT(C/16):N2=C-N1*16:H$=H$+MID$("0123456789ABCDEF",N1+1,1)+MID$("0123456789ABCDEF",N2+1,1):NEXT I:PRINT A$;" PF ";H$:RETURN
300 S=0:FOR I=1 TO LEN(D$):S=S+ASC(MID$(D$,I,1)):NEXT I:PRINT A$;" MF ";S:RETURN
400 V$="":FOR I=1 TO LEN(D$):IF MID$(D$,I,1)="," THEN V$=V$+"|" ELSE V$=V$+MID$(D$,I,1)
410 NEXT I:PRINT A$;" VF ";V$:RETURN
500 E$="":FOR I=1 TO LEN(D$):E$=E$+CHR$(ASC(MID$(D$,I,1))+1):NEXT I:PRINT A$;" AF ";E$:RETURN
1000 DATA "B1","PF","HELLO"
1010 DATA "B2","MF","ABC123"
1020 DATA "B3","VF","A,B,C,D"
1030 DATA "B4","AF","BASIC"
1040 DATA "END","",""
