10 CLS
20 PRINT "=== SISTEMA TOTAL HW+OOP+MATH ==="
30 TRON
40 DEFSEG 0
50 K=INT(PEEK(HEXVAL("6B4"))/4)+PEEK(HEXVAL("6B5"))*64
60 IF K<1 THEN K=32
70 PRINT "MEMCFG K=";K
80 M0=PEEK(0):M1=PEEK(1):M2=PEEK(2):M3=PEEK(3)
90 H0$=RIGHT$(HEX$(M0),2):H1$=RIGHT$(HEX$(M1),2):H2$=RIGHT$(HEX$(M2),2):H3$=RIGHT$(HEX$(M3),2)
100 PRINT "HW HEX=";H0$;" ";H1$;" ";H2$;" ";H3$
110 TYPE SENSOR
120 DEF PROC SENSOR.SCORE, PROP("BASE")+ABS(X)+SGN(Y)+INT(Z)
130 DEF PROC SENSOR.VMAG, SQR(PROP("VX")*PROP("VX")+PROP("VY")*PROP("VY"))
140 CLASS ENGINE
150 METHOD ENGINE,POWER,PROP("BOOST")+X*Y+NFUNC("FX",X)
160 METHOD ENGINE,TAG,PROP("NAME")+"@"+STR$(X)
170 FUNCTION FX, X*X+NPR(6,2)-NCR(6,2)
180 FUNCTION$ SBUILD$, LEFT$(X$,3)+"-"+MID$(X$,2,2)+"-"+RIGHT$(X$,2)
190 NEWFUNCTION MIX, POL(X,3)+ANGLE(X,1)
200 NEWFUNCTION$ HEXTAG$, "HX"+RIGHT$(HEX$(ASC(LEFT$(X$,1))),2)
210 DIM ENG AS ENGINE
220 DIM SNS AS SENSOR
230 SETPROP ENG,BOOST,20
240 SETPROP ENG,NAME,"CORE"
250 SETPROP SNS,BASE,7
260 SETPROP SNS,VX,3
270 SETPROP SNS,VY,4
280 DIM LOG$(24),A(5),B$(3)
290 DATA 2,4,6,8,10,12
300 FOR I=0 TO 5
302 READ T
304 A(I)=T
306 NEXT I
310 B$(0)="ALFA":B$(1)="BETA":B$(2)="GAMMA":B$(3)="OMEGA"
320 S$=B$(0)+"|"+B$(1)+"|"+B$(2)+"|"+B$(3)
330 L=LEN(S$):P=LOCATE$(S$,"GAM")
340 PRINT "STR LEN=";L;" LOCATE$=";P
350 PRINT "CHR/ASC=";CHR$(65);ASC("Z")
360 PRINT "VAL/STR/INT$=";VAL("123.5")+1;STR$(K);INT$(K/3)
370 T1=SIN(1)+COS(1)+TAN(1)+ASN(0.5)+ACS(0.5)+ATN(1)
380 T2=HSIN(1)+HCOS(1)+HTAN(1)+HASN(1)+HACS(2)+HATN(0.5)
390 T3=LOG(100)+LN(EXP(1))+SQR(81)+FACT(5)+NPR(5,2)+NCR(5,2)
400 T4=POL(3,4)+ANGLE(1,1)+REC(10,30,0)+REC(10,30,1)
410 T5=FRAC(7.25)+FIX(-4.9)+ROUND(8.6)+ABS(-7)+SGN(-2)+PI+RAN#
420 PRINT "MATH SUMS=";T1;T2;T3;T4;T5
430 PWR=CALL("ENG","POWER",4,3)
440 TAG$=CALL("ENG","TAG",9,0)
450 SC=CALL("SNS","SCORE",-5,2,3.9)
460 VM=CALL("SNS","VMAG",0,0,0)
470 MX=NFUNC("MIX",7)
480 SB$=NFUNC$("SBUILD$","JUANCARLOS")
490 HX$=NFUNC$("HEXTAG$","BASIC")
500 PRINT "OOP PWR=";PWR;" TAG=";TAG$
510 PRINT "SENSOR SCORE=";SC;" VMAG=";VM
520 PRINT "NFUNC MIX=";MX;" SBUILD=";SB$;" HEXTAG=";HX$
530 DEFSEG 0
540 POKE 500,INT(T3) MOD 256
550 POKE 501,INT(T4) MOD 256
560 PK=PEEK(500)+PEEK(501)
570 PRINT "PEEKSUM=";PK
580 LOG$(0)="SYS=TOTAL"
590 LOG$(1)="K="+STR$(K)
600 LOG$(2)="HW="+H0$+H1$+H2$+H3$
610 LOG$(3)="STRLEN="+STR$(L)
620 LOG$(4)="LOC="+STR$(P)
630 LOG$(5)="PWR="+STR$(PWR)
640 LOG$(6)="TAG="+TAG$
650 LOG$(7)="SC="+STR$(SC)
660 LOG$(8)="VM="+STR$(VM)
670 LOG$(9)="MIX="+STR$(MX)
680 LOG$(10)="SB="+SB$
690 LOG$(11)="HX="+HX$
700 LOG$(12)="T1="+STR$(T1)
710 LOG$(13)="T2="+STR$(T2)
720 LOG$(14)="T3="+STR$(T3)
730 LOG$(15)="T4="+STR$(T4)
740 LOG$(16)="T5="+STR$(T5)
750 LOG$(17)="PK="+STR$(PK)
760 LOG$(18)="HEXPK="+HEX$(PK)
770 LOG$(19)="ARR0="+STR$(A(0))+" ARR5="+STR$(A(5))
780 LOG$(20)="B0="+B$(0)+" B3="+B$(3)
790 LOG$(21)="LEFT="+LEFT$(S$,4)+" MID="+MID$(S$,6,4)+" RIGHT="+RIGHT$(S$,5)
800 LOG$(22)="TIMEFLAG="+CHR$(65)+CHR$(66)+CHR$(67)
810 LOG$(23)="END=OK"
820 LOG$(24)="READYFLAG=1"
830 OPEN "lessons/sistema_total_log.txt","W"
840 FOR I=0 TO 24
850 PRINT# LOG$(I)
860 NEXT I
870 CLOSE
880 OPEN "lessons/sistema_total_log.txt","R"
890 FOR I=0 TO 5
900 INPUT# L$:PRINT "LOGFILE";I;"=";L$
910 NEXT I
920 CLOSE
930 TRY 980
940 Z=CALL("NOEXISTE","POWER",1,1)
950 PRINT "NO ERROR"
960 CATCH
970 GOTO 1000
980 PRINT "TRY/CATCH TECNICO OK"
990 RESUME 1000
1000 CATCH
1010 TROFF
1020 PRINT "FIN SISTEMA TOTAL"
1030 END
