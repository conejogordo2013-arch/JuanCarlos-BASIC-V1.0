10 CLS
20 PRINT "TRADUCCION PYTHON -> JC BASIC"
30 NUM_WORKERS=5:NUM_JOBS=10:RETRY_MAX=2
40 DIM W$(NUM_WORKERS),REG$(2),FAILS(NUM_JOBS),OKS(NUM_JOBS)
50 FOR I=1 TO NUM_WORKERS:W$(I)="WORKER-"+STR$(I):NEXT I
60 REG$(0)="LOGGER":REG$(1)="WORKER":REG$(2)="JOBMANAGER"
70 PRINT "INICIANDO JOBS..."
80 FOR JOB=1 TO NUM_JOBS
90   IDX=INT(RAN#*NUM_WORKERS)+1
100  WN$=W$(IDX)
110  PRINT "[JOBMANAGER] INICIANDO TRABAJO-";JOB;" CON ";WN$
120  GOSUB 1000
130 NEXT JOB
140 PRINT
150 PRINT "-- CLASES REGISTRADAS AUTOMATICAMENTE --"
160 FOR I=0 TO 2:PRINT REG$(I):NEXT I
170 PRINT "RESUMEN: OK=";TOTOK;" FAIL=";TOTFAIL
180 PRINT "FIN"
190 END
1000 ATT=0
1010 ATT=ATT+1
1020 IF RAN#<0.5 THEN 1060
1030 PRINT "[WORKER] ";WN$;" TERMINO EL TRABAJO CON EXITO"
1040 TOTOK=TOTOK+1:OKS(JOB)=1
1050 RETURN
1060 PRINT "[INTENTO ";ATT;"] ERROR: ";WN$;" FALLO"
1070 IF ATT<RETRY_MAX THEN 1010
1080 PRINT "[JOBMANAGER] TRABAJO-";JOB;" FALLO CON ";WN$;": FALLO DESPUES DE ";RETRY_MAX;" INTENTOS"
1090 TOTFAIL=TOTFAIL+1:FAILS(JOB)=1
1100 RETURN
