10 CLS
20 PRINT "JC BASIC AUDIO LIB V1"
30 GOSUB 1000
35 OPEN "audio_demo.wav","W":PRINT# "RIFF_FAKE_WAVE_STEREO":CLOSE
40 AUDIO_PATH$="audio_demo.wav"
50 GOSUB 2000
60 IF AUDIO_ERR_CODE<>0 THEN GOTO 9500
70 GOSUB 7000
80 GOSUB 3000
90 GOSUB 4000
100 GOSUB 5000
110 GOSUB 6000
120 PRINT "DEMO FINALIZADO"
130 END
1000 AUDIO_PATH$="":AUDIO_FMT$="":AUDIO_STATE$="STOPPED":AUDIO_LOADED=0
1010 AUDIO_DURATION=0:AUDIO_CHANNELS=0:AUDIO_RATE=0:AUDIO_ERR$="":AUDIO_ERR_CODE=0
1020 AUDIO_POS=0
1030 RETURN
2000 AUDIO_ERR$="":AUDIO_ERR_CODE=0
2010 IF AUDIO_PATH$="" THEN AUDIO_ERR_CODE=1:AUDIO_ERR$="RUTA VACIA":GOSUB 8000:RETURN
2020 AUDIO_FMT$="UNKNOWN"
2030 IF RIGHT$(AUDIO_PATH$,4)=".wav" OR RIGHT$(AUDIO_PATH$,4)=".WAV" THEN AUDIO_FMT$="WAV"
2040 IF RIGHT$(AUDIO_PATH$,4)=".ogg" OR RIGHT$(AUDIO_PATH$,4)=".OGG" THEN AUDIO_FMT$="OGG"
2050 IF RIGHT$(AUDIO_PATH$,4)=".mp3" OR RIGHT$(AUDIO_PATH$,4)=".MP3" THEN AUDIO_FMT$="MP3"
2060 IF AUDIO_FMT$="UNKNOWN" THEN AUDIO_ERR_CODE=2:AUDIO_ERR$="FORMATO NO SOPORTADO":GOSUB 8000:RETURN
2070 OPEN AUDIO_PATH$,"R"
2080 INPUT# HDR$
2090 CLOSE
2100 IF AUDIO_FMT$="WAV" THEN 2130
2110 IF AUDIO_FMT$="OGG" THEN AUDIO_CHANNELS=2:AUDIO_RATE=48000:AUDIO_DURATION=120.5:GOTO 2160
2120 IF AUDIO_FMT$="MP3" THEN AUDIO_CHANNELS=2:AUDIO_RATE=44100:AUDIO_DURATION=180.0:GOTO 2160
2130 IF LOCATE$(HDR$,"RIFF")=0 OR LOCATE$(HDR$,"WAVE")=0 THEN AUDIO_ERR_CODE=3:AUDIO_ERR$="WAV INVALIDO":GOSUB 8000:RETURN
2140 AUDIO_CHANNELS=2:AUDIO_RATE=44100:AUDIO_DURATION=95.75
2150 IF LOCATE$(HDR$,"MONO")>0 THEN AUDIO_CHANNELS=1
2160 AUDIO_LOADED=1:AUDIO_STATE$="STOPPED":AUDIO_POS=0
2170 RETURN
3000 IF AUDIO_LOADED=0 THEN AUDIO_ERR_CODE=4:AUDIO_ERR$="NO HAY AUDIO CARGADO":GOSUB 8000:RETURN
3010 AUDIO_STATE$="PLAYING":AUDIO_POS=0
3020 PRINT "PLAY -> ";AUDIO_PATH$
3030 RETURN
4000 IF AUDIO_LOADED=0 THEN AUDIO_ERR_CODE=4:AUDIO_ERR$="NO HAY AUDIO CARGADO":GOSUB 8000:RETURN
4010 IF AUDIO_STATE$<>"PLAYING" THEN AUDIO_ERR_CODE=5:AUDIO_ERR$="NO ESTA REPRODUCIENDO":GOSUB 8000:RETURN
4020 AUDIO_STATE$="PAUSED":AUDIO_POS=AUDIO_POS+1
4030 PRINT "PAUSE"
4040 RETURN
5000 IF AUDIO_LOADED=0 THEN AUDIO_ERR_CODE=4:AUDIO_ERR$="NO HAY AUDIO CARGADO":GOSUB 8000:RETURN
5010 IF AUDIO_STATE$<>"PAUSED" THEN AUDIO_ERR_CODE=6:AUDIO_ERR$="NO ESTA EN PAUSA":GOSUB 8000:RETURN
5020 AUDIO_STATE$="PLAYING"
5030 PRINT "RESUME"
5040 RETURN
6000 IF AUDIO_LOADED=0 THEN AUDIO_ERR_CODE=4:AUDIO_ERR$="NO HAY AUDIO CARGADO":GOSUB 8000:RETURN
6010 AUDIO_STATE$="STOPPED":AUDIO_POS=0
6020 PRINT "STOP"
6030 RETURN
7000 IF AUDIO_LOADED=0 THEN AUDIO_ERR_CODE=4:AUDIO_ERR$="NO HAY AUDIO CARGADO":GOSUB 8000:RETURN
7010 PRINT "INFO FORMATO=";AUDIO_FMT$
7020 PRINT "INFO DURACION=";AUDIO_DURATION;" SEG"
7030 PRINT "INFO CANALES=";AUDIO_CHANNELS
7040 PRINT "INFO RATE=";AUDIO_RATE;" HZ"
7050 PRINT "INFO ESTADO=";AUDIO_STATE$
7060 RETURN
8000 PRINT "ERROR[";AUDIO_ERR_CODE;"] ";AUDIO_ERR$
8010 RETURN
9500 PRINT "DEMO ABORTADA POR ERROR"
9510 END
