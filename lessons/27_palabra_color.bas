10 CLS
20 INPUT "ESCRIBE UNA PALABRA";W$
30 INPUT "ESCRIBE UN COLOR (RED/BLUE/GREEN/YELLOW)";C$
40 H$="FFFFFF":OK=0
50 IF C$="RED" THEN H$="FF0000":OK=1
60 IF C$="BLUE" THEN H$="0000FF":OK=1
70 IF C$="GREEN" THEN H$="00FF00":OK=1
80 IF C$="YELLOW" THEN H$="FFFF00":OK=1
90 IF C$="red" THEN H$="FF0000":OK=1
100 IF C$="blue" THEN H$="0000FF":OK=1
110 IF C$="green" THEN H$="00FF00":OK=1
120 IF C$="yellow" THEN H$="FFFF00":OK=1
130 IF OK=0 THEN PRINT "COLOR NO RECONOCIDO, USANDO BLANCO"
140 X$=LCOLOR(H$)
150 PRINT W$
160 X$=LCOLOR("FFFFFF")
170 END
