10 CLS
20 PRINT "=== OOP COMPLEJO JC BASIC ==="
30 TRON
40 TYPE VECTOR
50 DEF PROC VECTOR.NORM2, PROP("X")*PROP("X")+PROP("Y")*PROP("Y")
60 DEF PROC VECTOR.SCALEX, PROP("X")*X
70 DEF PROC VECTOR.SCALEY, PROP("Y")*X
80 CLASS ROBOT
90 METHOD ROBOT,POWER,PROP("BASE")+X*Y+NFUNC("BOOST",X)
100 METHOD ROBOT,TAG,PROP("NAME")+"#"+STR$(X)
110 FUNCTION BOOST, X*X+3
120 FUNCTION$ MKID$, LEFT$(X$,3)+"-"+RIGHT$(X$,2)
130 DIM R1 AS ROBOT
140 DIM R2 AS ROBOT
150 DIM V1 AS VECTOR
160 DIM LOG$(8),PWR(4)
170 SETPROP R1,BASE,10
180 SETPROP R2,BASE,25
190 SETPROP R1,NAME,"ALFA"
200 SETPROP R2,NAME,"BETA"
210 SETPROP V1,X,3
220 SETPROP V1,Y,4
230 PRINT "V1 NORM2=";CALL("V1","NORM2",0,0)
240 PRINT "V1 SCALEX2=";CALL("V1","SCALEX",2,0)
250 PRINT "V1 SCALEY3=";CALL("V1","SCALEY",3,0)
260 FOR I=0 TO 4
270 PWR(I)=CALL("R1","POWER",I+1,2)+CALL("R2","POWER",I+1,1)
280 NEXT I
290 FOR I=0 TO 4
300 PRINT "PWR(";I;")=";PWR(I)
310 NEXT I
320 LOG$(0)=NFUNC$("MKID$","ALFA99")
330 LOG$(1)=NFUNC$("MKID$","BETA77")
340 LOG$(2)="TAG1="+CALL("R1","TAG",7,0)
350 LOG$(3)="TAG2="+CALL("R2","TAG",9,0)
360 LOG$(4)="SUM="+STR$(PWR(0)+PWR(1)+PWR(2)+PWR(3)+PWR(4))
370 LOG$(5)="MAX="+STR$(PWR(4))
380 LOG$(6)="MIN="+STR$(PWR(0))
390 LOG$(7)="NORM="+STR$(CALL("V1","NORM2",0,0))
400 LOG$(8)="DONE"
410 FOR I=0 TO 8
420 PRINT "LOG";I;"=";LOG$(I)
430 NEXT I
440 OPEN "lessons/oop_complejo_log.txt","W"
450 FOR I=0 TO 8
460 PRINT# LOG$(I)
470 NEXT I
480 CLOSE
490 OPEN "lessons/oop_complejo_log.txt","R"
500 FOR I=0 TO 8
510 INPUT# L$:PRINT "FILE";I;"=";L$
520 NEXT I
530 CLOSE
540 TRY 620
550 Z=CALL("R3","POWER",1,1)
560 PRINT "NO ERROR"
570 CATCH
580 GOTO 650
620 PRINT "TRY/CATCH OOP OK"
630 RESUME 650
640 CATCH
650 ON 2 GOSUB 700,720,740
660 ON 1 GOTO 760,780
670 PRINT "NO LLEGA"
680 GOTO 800
700 PRINT "ON GOSUB A":RETURN
720 PRINT "ON GOSUB B":RETURN
740 PRINT "ON GOSUB C":RETURN
760 PRINT "ON GOTO A":GOTO 800
780 PRINT "ON GOTO B":GOTO 800
800 TROFF
810 PRINT "FIN OOP COMPLEJO"
820 END
