10 CLS
20 PRINT "LECCION 4: BASICO TOTAL"
30 INPUT "NOMBRE";N$
40 INPUT "EDAD";E
50 PRINT "HOLA ";N$;" EDAD=";E
60 A=5:B=2:PRINT "A=";A;" B=";B
70 PRINT "A+B=";A+B;" A-B=";A-B;" A*B=";A*B;" A/B=";A/B;" A^B=";A^B
80 IF E>=18 THEN GOTO 100
90 GOTO 110
100 PRINT "MAYOR DE EDAD"
105 GOTO 120
110 PRINT "MENOR DE EDAD"
120 FOR I=1 TO 3
130 PRINT "FOR I=";I
140 NEXT I
150 J=3
160 WHILE J>0
170 PRINT "WHILE J=";J
180 J=J-1
190 WEND
200 K=1
210 IF K=1 THEN GOTO 240
220 PRINT "ESTA LINEA NO DEBE VERSE"
230 GOTO 250
240 PRINT "SALTO CON GOTO OK"
250 PRINT "FIN LECCION 4"
260 END
