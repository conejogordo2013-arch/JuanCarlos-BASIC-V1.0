10 CLS:DEFSEG 0:K=INT(PEEK(HEXVAL("6B4"))/4)+PEEK(HEXVAL("6B5"))*64
20 IF K<32 THEN K1=8:K2=K-K1
30 IF K=32 OR K=64 THEN K1=32:K2=K-K1
40 IF K=40 THEN POKE HEXVAL("8000"),10:POKE 0,0:IF PEEK(HEXVAL("A000"))=10 THEN K1=32:K2=8 ELSE K1=8:K2=32
50 PRINT "Main ";K1;" Kbyte Option ";K2;" Kbyte"
60 A=64:D=1:A1=0
70 GOSUB 1000:A=A+A:D=(D+D) MOD 256:IF A<K*1024 THEN 70
80 FOR I=1 TO 9
90 A=K*1024-A1-1:IF I=5 OR I=9 THEN D=HEXVAL("80") ELSE D=HEXVAL("20")
100 GOSUB 1010:IF A1=0 THEN A1=1 ELSE A1=A1*2
110 NEXT
120 A=K*1024-A1-1:GOSUB 1000:A1=A1*2:IF A1<K*1024 THEN 120
130 PRINT "OK RAM":GOSUB 10000:PRINT:DEFSEG HEXVAL("4000")
