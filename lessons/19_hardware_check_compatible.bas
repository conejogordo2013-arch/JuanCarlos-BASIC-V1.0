191 D4=PEEK(0):D5=PEEK(HEXVAL("5955")):D6=PEEK(HEXVAL("A6AA"))
192 IF PEEK(HEXVAL("FFFF"))<>HEXVAL("20") THEN PRINT "NG ROM 2":GOTO 1030
193 PRINT "OK 512K*2 ROM?":PRINT
194 PRINT RIGHT$(HEX$(D1),2);" ";RIGHT$(HEX$(D2),2);" ";RIGHT$(HEX$(D3),2);" ";RIGHT$(HEX$(D4),2);" ";RIGHT$(HEX$(D5),2);" ";RIGHT$(HEX$(D6),2)
195 GOTO 210
200 IF PEEK(ROM*128-1)<>HEXVAL("20") THEN PRINT "NG ROM 1":GOTO 1030
201 D1=PEEK(HEXVAL("5955")):IF ROM=256 THEN D2=PEEK(HEXVAL("26AA")) ELSE D2=PEEK(HEXVAL("A6AA"))
202 PRINT "OK ";ROM;" K ROM?":PRINT
203 PRINT RIGHT$(HEX$(D1),2);" ";RIGHT$(HEX$(D2),2)
210 GOSUB 10000
