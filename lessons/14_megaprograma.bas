10 CLS
20 PRINT "LECCION 14: MEGAPROGRAMA"
30 PRINT "LCOLOR=";LCOLOR("00FFAA")
40 FUNCTION FGLOBAL, X^2+NPR(5,2)
50 FUNCTION$ TAG$, LEFT$(X$,3)+"-"+RIGHT$(X$,2)
60 CLASS VEC
70 METHOD VEC,POWER,PROP("BASE")+X*Y+NFUNC("FGLOBAL",X)+Y
