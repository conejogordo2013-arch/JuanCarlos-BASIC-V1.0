170 GPHYCS 10,1,"#"
180 OPEN "lessons/mega_out.txt","W"
190 WRITE "TOT="+STR$(TOT)
200 WRITE "METHOD="+STR$(CALL("OBJ1","POWER",2,3))
210 CLOSE
220 OPEN "lessons/mega_out.txt","R"
230 READFILE L1$:READFILE L2$:CLOSE
240 PRINT "FILE1=";L1$
250 PRINT "FILE2=";L2$
260 TRY 320
270 OPEN "lessons/mega_out.txt","Z"
280 PRINT "NO LLEGA"
290 CATCH
300 GOTO 340
320 PRINT "TRY_OK"
330 CATCH
