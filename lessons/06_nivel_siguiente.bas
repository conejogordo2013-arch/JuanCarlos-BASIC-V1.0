10 CLS
20 PRINT "LECCION 6: NIVEL SIGUIENTE"
30 DIM DIR$(3)
40 DATA "NORTE","SUR","ESTE","OESTE"
50 FOR I=0 TO 3
60 READ DIR$(I)
70 NEXT I
80 DEFSEG 0
90 POKE 200,0
100 FOR T=1 TO 5
110 R=INT(RAN#*4)
120 PRINT "TURNO";T;" DIRECCION=";DIR$(R)
130 ON R+1 GOSUB 500,600,700,800
140 NEXT T
150 PRINT "PUNTAJE FINAL=";PEEK(200)
160 C$="CMD:GO"
170 PRINT "PREFIJO=";LEFT$(C$,3)
180 PRINT "CENTRO=";MID$(C$,5,2)
190 PRINT "SUFIJO=";RIGHT$(C$,2)
200 END
500 POKE 200,PEEK(200)+1:PRINT "EVENTO NORTE (+1)":RETURN
600 POKE 200,PEEK(200)+2:PRINT "EVENTO SUR (+2)":RETURN
700 POKE 200,PEEK(200)+3:PRINT "EVENTO ESTE (+3)":RETURN
800 POKE 200,PEEK(200)+4:PRINT "EVENTO OESTE (+4)":RETURN
