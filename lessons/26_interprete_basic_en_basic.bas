10 CLS
20 PRINT "MINI INTERPRETE BASIC EN JC BASIC"
30 DIM LIN(200),SRC$(200),V(25),VI(25),FVAR(10),FEND(10),FPC(10)
40 OPEN "lessons/demo_mini.bas","W"
50 PRINT# "10 PRINT "+CHR$(34)+"DEMO MINI BASIC"+CHR$(34)
60 PRINT# "20 INPUT A"
70 PRINT# "30 IF A>3 THEN 60"
80 PRINT# "40 PRINT "+CHR$(34)+"MENOR O IGUAL 3"+CHR$(34)
90 PRINT# "50 GOTO 70"
100 PRINT# "60 PRINT "+CHR$(34)+"MAYOR A 3"+CHR$(34)
110 PRINT# "70 FOR I=1 TO 3"
120 PRINT# "80 PRINT I"
130 PRINT# "90 NEXT I"
140 PRINT# "100 END"
150 CLOSE
160 SRCFILE$="lessons/demo_mini.bas":N=0
170 OPEN SRCFILE$,"R"
180 INPUT# L$
190 IF L$="" THEN GOTO 230
200 N=N+1:GOSUB 1000
210 GOTO 180
230 CLOSE
240 IF N=0 THEN PRINT "ERROR: PROGRAMA VACIO":END
250 PRINT "PROGRAMA CARGADO. LINEAS=";N
260 PC=1:FSP=0
270 IF PC<1 THEN PRINT "FIN INTERPRETE":END
280 IF PC>N THEN PRINT "FIN INTERPRETE":END
290 C$=SRC$(PC)
300 GOSUB 2000
310 GOTO 270
1000 SP=LOCATE$(L$," ")
1010 IF SP=0 THEN LIN(N)=VAL(L$):SRC$(N)="":RETURN
1020 LIN(N)=VAL(LEFT$(L$,SP-1))
1030 SRC$(N)=MID$(L$,SP+1,LEN(L$)-SP)
1040 RETURN
2000 IF C$="" THEN PC=PC+1:RETURN
2002 TOK$=C$:SPC=LOCATE$(TOK$," ")
2004 IF SPC>0 THEN TOK$=LEFT$(TOK$,SPC-1)
2010 IF TOK$="PRINT" THEN GOSUB 3000:RETURN
2020 IF TOK$="INPUT" THEN GOSUB 3100:RETURN
2025 IF LEFT$(C$,5)="INPUT" THEN GOSUB 3100:RETURN
2030 IF TOK$="GOTO" THEN GOSUB 3200:RETURN
2040 IF TOK$="IF" THEN GOSUB 3300:RETURN
2050 IF TOK$="FOR" THEN GOSUB 4400:RETURN
2060 IF TOK$="NEXT" THEN GOSUB 3500:RETURN
2070 IF TOK$="END" THEN PC=N+1:RETURN
2080 PRINT "ERROR: COMANDO NO SOPORTADO EN LINEA ";LIN(PC)
2090 PC=N+1
2100 RETURN
3000 A$=MID$(C$,7,LEN(C$)-6)
3010 IF LEFT$(A$,1)=CHR$(34) THEN GOTO 3040
3020 IF LEN(A$)=1 THEN GOTO 3060
3030 PRINT VAL(A$):PC=PC+1:RETURN
3040 PRINT MID$(A$,2,LEN(A$)-2)
3050 PC=PC+1:RETURN
3060 IDX=ASC(A$)-65
3070 IF VI(IDX)=0 THEN PRINT "ERROR: VARIABLE NO INICIALIZADA ";A$:PC=N+1:RETURN
3080 PRINT V(IDX)
3090 PC=PC+1:RETURN
3100 VN$=MID$(C$,7,1):IDX=ASC(VN$)-65
3110 INPUT VN
3120 V(IDX)=VN:VI(IDX)=1
3130 PC=PC+1:RETURN
3200 TL=VAL(MID$(C$,6,LEN(C$)-5))
3210 GOSUB 4000
3220 IF FOUND=0 THEN PRINT "ERROR: LINEA INEXISTENTE ";TL:PC=N+1:RETURN
3230 PC=TP:RETURN
3300 R$=MID$(C$,4,LEN(C$)-3)
3310 TPOS=LOCATE$(R$," THEN ")
3320 IF TPOS=0 THEN PRINT "ERROR IF THEN EN LINEA ";LIN(PC):PC=N+1:RETURN
3330 COND$=LEFT$(R$,TPOS-1)
3340 TL=VAL(MID$(R$,TPOS+6,LEN(R$)-(TPOS+5)))
3350 OPP=LOCATE$(COND$,">"):OP$=">"
3360 IF OPP>0 THEN GOTO 3390
3370 OPP=LOCATE$(COND$,"<"):OP$="<"
3380 IF OPP=0 THEN OPP=LOCATE$(COND$,"="):OP$="="
3390 VN$=LEFT$(COND$,OPP-1):RV=VAL(MID$(COND$,OPP+1,LEN(COND$)-OPP))
3400 IDX=ASC(VN$)-65
3410 IF VI(IDX)=0 THEN PRINT "ERROR: VARIABLE NO INICIALIZADA ";VN$:PC=N+1:RETURN
3420 OK=0
3430 IF OP$=">" THEN GOTO 3460
3440 IF OP$="<" THEN GOTO 3470
3450 GOTO 3480
3460 IF V(IDX)>RV THEN OK=1
3465 GOTO 3490
3470 IF V(IDX)<RV THEN OK=1
3475 GOTO 3490
3480 IF V(IDX)=RV THEN OK=1
3490 IF OK=0 THEN PC=PC+1:RETURN
3495 GOSUB 4000
3496 IF FOUND=0 THEN PRINT "ERROR: LINEA INEXISTENTE ";TL:PC=N+1:RETURN
3497 PC=TP:RETURN
4400 R$=MID$(C$,5,LEN(C$)-4)
4410 EP=LOCATE$(R$,"="):TOP=LOCATE$(R$," TO ")
4420 VN$=LEFT$(R$,EP-1)
4430 SV=VAL(MID$(R$,EP+1,TOP-EP-1))
4440 EV=VAL(MID$(R$,TOP+4,LEN(R$)-TOP-3))
4450 IDX=ASC(VN$)-65:V(IDX)=SV:VI(IDX)=1
4460 FSP=FSP+1:FVAR(FSP)=IDX:FEND(FSP)=EV:FPC(FSP)=PC
4470 PC=PC+1:RETURN
3500 IF FSP<=0 THEN PRINT "ERROR: NEXT SIN FOR":PC=N+1:RETURN
3510 IDX=FVAR(FSP):V(IDX)=V(IDX)+1
3520 IF V(IDX)<=FEND(FSP) THEN PC=FPC(FSP)+1:RETURN
3530 FSP=FSP-1
3540 PC=PC+1:RETURN
4000 FOUND=0
4010 FOR J=1 TO N
4020 IF LIN(J)=TL THEN TP=J:FOUND=1
4030 NEXT J
4040 RETURN
