10 CLS
20 PRINT "PROYECTO FINAL: ANALIZADOR JC"
30 DIM V(4),R(4),M(1,1)
40 DATA 3,7,11,19,23
50 FOR I=0 TO 4
60 READ T
70 V(I)=T
80 NEXT I
90 FOR I=0 TO 4
100 R(I)=ROUND((V(I)^2+SQR(V(I)*10))/3)
110 NEXT I
120 M(0,0)=R(0):M(0,1)=R(1)
130 M(1,0)=R(2):M(1,1)=R(3)
140 DET=M(0,0)*M(1,1)-M(0,1)*M(1,0)
150 DEFSEG 0
160 POKE 220,INT(ABS(DET))
170 POKE 221,LEN("JC")+ASC("A")
180 PRINT "VECTOR R=";R(0);",";R(1);",";R(2);",";R(3);",";R(4)
190 PRINT "DET=";DET;" MEM220_ESCRITO=";INT(ABS(DET));" MEM221_ESCRITO=";LEN("JC")+ASC("A")
200 C$="JC:FINAL"
210 PRINT "TOKENS=";LEFT$(C$,2);"|";MID$(C$,4,5);"|";RIGHT$(C$,3)
220 X=2
230 ON X GOSUB 500,600,700
240 PRINT "POST-EVENTO"
250 Y=3
260 ON Y GOTO 800,900,950
270 PRINT "NO LLEGA"
500 PRINT "EV1 FACT(5)=";FACT(5):RETURN
600 PRINT "EV2 EXP/LN=";LN(EXP(2)):RETURN
700 PRINT "EV3 RAN#=";RAN#:RETURN
800 PRINT "RUTA 1":GOTO 990
900 PRINT "RUTA 2":GOTO 990
950 PRINT "RUTA 3":GOTO 990
990 PRINT "FIN PROYECTO FINAL"
995 END
