10 CLS
20 PRINT "LECCION 16: ULTRA COMPLEJO"
30 TYPE CALC
40 DEF PROC CALC.MIX, PROP("BASE")+X*Y+SQR(X^2+Y^2)
50 DIM OBJ AS CALC
60 OBJ.BASE=5
70 DEF FN SCORE, X*X+NCR(6,2)
80 DIM A(4),B$(2)
90 DATA 3,6,9,12,15
100 FOR I=0 TO 4:READ T:A(I)=T:NEXT I
110 FOR I=0 TO 4:SUM=SUM+A(I):NEXT I
120 B$(0)="JUAN":B$(1)="CARLOS":B$(2)="BASIC"
130 NAME$=B$(0)+"-"+B$(2)
140 M=CALL("OBJ","MIX",3,4)
150 F=NFUNC("SCORE",7)
160 DEFSEG 0
170 POKE 300,INT(SUM)
180 POKE 301,INT(M)
190 PMEM=PEEK(300)+PEEK(301)
200 OPEN "lessons/ultra_out.txt","W"
210 PRINT# "SUM="+STR$(SUM)
220 PRINT# "MIX="+STR$(M)
230 PRINT# "FN="+STR$(F)
240 PRINT# "MEM="+STR$(PMEM)
250 CLOSE
260 OPEN "lessons/ultra_out.txt","R"
270 INPUT# L1$:INPUT# L2$:INPUT# L3$:INPUT# L4$
280 CLOSE
290 PRINT "ARCHIVO1=";L1$
300 PRINT "ARCHIVO2=";L2$
310 PRINT "ARCHIVO3=";L3$
320 PRINT "ARCHIVO4=";L4$
330 PRINT "NAME$=";NAME$;" LEN=";LEN(NAME$)
340 PRINT "LEFT=";LEFT$(NAME$,4);" MID=";MID$(NAME$,6,5);" RIGHT=";RIGHT$(NAME$,5)
350 PRINT "HEX=";HEX$(255);" HEXVAL=";HEXVAL("FF")
360 PRINT "POL=";POL(3,4);" ANG=";ANGLE(1,1);" RECX=";REC(10,30,0)
370 PRINT "MOD=";PMEM MOD 7
380 LOAD("lessons/import_math.bas","ULTRA",1)
390 PRINT "FIN 16"
400 END
